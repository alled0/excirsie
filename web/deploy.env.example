# Copy values from here into your cloud provider's secret/config system.
# Do not commit real production secrets.

# Spring Boot backend
PROJECT_ID=your-gcp-project-id
REGION=europe-west1
ARTIFACT_REPO=taharrak
MODEL_SERVICE_NAME=taharrak-model-service
BACKEND_SERVICE_NAME=taharrak-backend

# demo = no Cloud SQL, lowest-cost/free-first deploy. Data can reset.
# prod = PostgreSQL on Cloud SQL, durable production deploy.
DEPLOY_MODE=demo
SPRING_PROFILES_ACTIVE=demo

# Filled by deployment after the first Cloud Run deploy, unless using custom domains.
MODEL_SERVICE_URL=
BACKEND_URL=

# Required only for DEPLOY_MODE=prod.
DB_URL=jdbc:postgresql://<host>:5432/taharrak
DB_USER=taharrak_app
DB_PASS=<store-in-secret-manager>
DB_PASS_SECRET=taharrak-db-pass:latest
APP_CORS_ALLOWED_ORIGINS=*

# Frontend runtime config values
# Write these into frontend/src/assets/runtime-config.json before build,
# or replace that file during static hosting deploy.
# Use /api only when your static host rewrites /api to the backend.
# Otherwise use the full backend URL, for example:
# https://taharrak-backend.example.com/api
FRONTEND_API_BASE=
FRONTEND_MODEL_BASE=
FRONTEND_WS_BASE=

# Future upload pipeline
UPLOAD_BUCKET=taharrak-uploads
RESULT_BUCKET=taharrak-results
PROCESSING_QUEUE=taharrak-video-processing
